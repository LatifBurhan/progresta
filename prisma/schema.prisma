generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String     @id @default(uuid()) @db.Uuid
  email      String     @unique
  password   String
  role       Role       @default(KARYAWAN)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  createdBy  String?    @db.Uuid
  divisionId String?    @db.Uuid
  status     UserStatus @default(PENDING)
  profile    Profile?
  reports    Report[]
  division   Division?  @relation(fields: [divisionId], references: [id])

  @@map("users")
}

model Profile {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @unique @db.Uuid
  fotoProfil String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  name       String?
  phone      String?
  position   String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Division {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  color       String?
  createdAt   DateTime  @default(now())
  isActive    Boolean   @default(true)
  updatedAt   DateTime  @updatedAt
  projects    Project[]
  users       User[]

  @@map("divisions")
}

model Project {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  createdAt     DateTime       @default(now())
  divisionId    String         @db.Uuid
  endDate       DateTime?
  isActive      Boolean        @default(true)
  startDate     DateTime?
  updatedAt     DateTime       @updatedAt
  division      Division       @relation(fields: [divisionId], references: [id])
  reportDetails ReportDetail[]

  @@map("projects")
}

model Report {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @db.Uuid
  reportDate    DateTime
  reportTime    DateTime
  period        String
  hasIssue      Boolean        @default(false)
  issueDesc     String?
  totalHours    Float          @default(2.0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  reportDetails ReportDetail[]
  user          User           @relation(fields: [userId], references: [id])

  @@unique([userId, reportDate, period])
  @@map("reports")
}

model ReportDetail {
  id         String   @id @default(uuid()) @db.Uuid
  reportId   String   @db.Uuid
  projectId  String   @db.Uuid
  task       String
  progress   String
  evidence   String?
  hoursSpent Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id])
  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_details")
}

enum Role {
  ADMIN
  USER
  HRD
  PM
  CEO
  KARYAWAN
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}
