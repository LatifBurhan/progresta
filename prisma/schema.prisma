generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
}

// Enum untuk status user
enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
}

// Model sesuai dengan struktur database yang sebenarnya
model User {
  id            String     @id @db.Uuid
  email         String     @unique
  // name field tidak ada di database, jadi dihapus
  role          String     @default("KARYAWAN") // Sesuai constraint database (uppercase)
  divisionId    String?    @map("divisionId") @db.Uuid // Map ke divisionId (camelCase di database)
  statusPending Boolean    @default(true) @map("status_pending")
  status        UserStatus @default(ACTIVE) // Use enum instead of String
  createdAt     DateTime   @default(now()) @map("createdAt")
  updatedAt     DateTime   @default(now()) @updatedAt @map("updatedAt")
  
  // Relations
  division      Division? @relation(fields: [divisionId], references: [id])
  reports       Report[]
  projectAssignments ProjectAssignment[]

  @@map("users")
}

model Division {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name        String    @unique
  description String?
  color       String?   @default("#3B82F6")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  users       User[]
  projectDivisions ProjectDivision[]

  @@map("divisions")
}

model Project {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name        String
  client      String?
  description String?
  startDate   DateTime? @map("start_date") @db.Timestamp(6)
  endDate     DateTime? @map("end_date") @db.Timestamp(6)
  statusActive Boolean? @default(true) @map("status_active")
  isActive    Boolean?  @default(true) @map("is_active")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  projectAssignments ProjectAssignment[]
  projectDivisions   ProjectDivision[]
  reportDetails      ReportDetail[]

  @@map("projects")
}

model ProjectAssignment {
  id        String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  createdAt DateTime? @default(now()) @map("created_at")
  
  // Relations
  user      User      @relation(fields: [userId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])

  @@map("project_assignments")
}

model ProjectDivision {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String    @map("project_id") @db.Uuid
  divisionId String    @map("division_id") @db.Uuid
  createdAt  DateTime? @default(dbgenerated("CURRENT_TIMESTAMP")) @map("created_at") @db.Timestamp(6)
  
  // Relations
  project    Project   @relation(fields: [projectId], references: [id])
  division   Division  @relation(fields: [divisionId], references: [id])

  @@map("project_divisions")
}

model Report {
  id         String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  location   String    @default("Kantor") // 'Kantor', 'Lokasi Proyek', 'Remote'
  period     String    // '08-10', '10-12', '12-14', '14-16'
  futurePlan String    @map("future_plan")
  photoUrl   String?   @map("photo_url")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @updatedAt @map("updated_at")
  
  // Relations
  user          User           @relation(fields: [userId], references: [id])
  reportDetails ReportDetail[]

  @@map("reports")
}

model ReportDetail {
  id        String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  reportId  String    @map("report_id") @db.Uuid
  projectId String    @map("project_id") @db.Uuid
  progress  String
  issues    String?
  createdAt DateTime? @default(now()) @map("created_at")
  
  // Relations
  report    Report    @relation(fields: [reportId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])

  @@map("report_details")
}
